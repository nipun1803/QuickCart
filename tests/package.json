{
  "name": "quickcart",
  "version": "1.0.0",
  "description": "**QuickCart** is a modern, responsive e-commerce web application built with React and Vite. It provides a seamless online shopping experience with a clean, intuitive interface for browsing and purchasing products.",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test:unit:backend": "TMPDIR=/tmp vitest run -c vitest.backend.config.js",
    "test:unit:frontend": "TMPDIR=/tmp vitest run -c vitest.frontend.config.js",
    "test:integration": "TMPDIR=/tmp vitest run -c vitest.integration.config.js",
    "test:backend": "npm run test:unit:backend",
    "test:frontend": "npm run test:unit:frontend",
    "test:e2e": "TMPDIR=/tmp npx playwright test -c playwright.config.js",
    "test:all": "npm run test:unit:backend && npm run test:unit:frontend && npm run test:integration && npm run test:e2e"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nipun1803/QuickCart.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/nipun1803/QuickCart/issues"
  },
  "homepage": "https://github.com/nipun1803/QuickCart#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.3.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/ui": "^4.0.18",
    "dotenv": "^17.3.1",
    "jsdom": "^28.1.0",
    "supertest": "^7.2.2",
    "vitest": "^4.1.0"
  }
}